<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>interbotix_ux_ros_control</name>
  <version>0.0.0</version>
  <description>ROS 2 control bridge for Interbotix uArm (xArm) - position interface to xarm_api</description>
  <maintainer email="trsupport@trossenrobotics.com">Solomon Wiznitzer</maintainer>
  <license>BSD</license>
  <author email="solomon@trossenrobotics.com">Solomon Wiznitzer</author>
  <buildtool_depend>ament_cmake</buildtool_depend>
  <depend>rclcpp</depend>
  <depend>sensor_msgs</depend>
  <depend>xarm_msgs</depend>
  <depend>xarm_api</depend>
  <export><build_type>ament_cmake</build_type></export>
</package>
